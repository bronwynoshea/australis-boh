{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "imports/upstream-apps/loft-app/src/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "imports/upstream-apps/loft-app"],
  "exclude": [
    "node_modules",
    "dist",
    "src/_archive",
    "boh-counter",
    "boh-marketing",
    "boh-results",
    "supabase/functions/**",
    "supabase/functions/**/*"
  ]
}