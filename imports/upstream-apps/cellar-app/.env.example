# Cellar local environment variables
# Copy to .env and fill in local/dev values. Do not commit .env.

# BOH-DEV / BOH Supabase
VITE_CELLAR_APP_URL=
VITE_CELLAR_SUPABASE_PROJECT_ID=
VITE_CELLAR_SUPABASE_URL=
VITE_CELLAR_SUPABASE_PUBLISHABLE_KEY=

# Edge Function email notifications. Configure as Supabase secrets in BOH-DEV, not browser env vars.
CELLAR_RESEND_API_KEY=
CELLAR_EMAIL_FROM=CELLAR <noreply@auth.jobzcafe.com>
CELLAR_NOTIFICATION_EMAILS=boshea@jobzcafe.com,alanum@jobzcafe.com

